# App
APP_ENV=development
LOG_LEVEL=INFO
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-secret-from-secret-manager
SESSION_TIMEOUT_MINUTES=480
PASSWORD_MIN_LENGTH=12
MFA_REQUIRED_FOR_ADMINS=true

# Database
DATABASE_URL=postgresql://axieme:axieme@localhost:5432/axieme_mga?schema=public

# Google Cloud Platform
GCP_PROJECT_ID=axieme-mga-demo
GCP_REGION=europe-west8
GCP_STORAGE_BUCKET=axieme-mga-private-documents
GCP_KMS_KEY_ID=
GCP_SECRET_MANAGER_PREFIX=axieme-mga
AUDIT_LOG_RETENTION_DAYS=3650

# Security
SIGNED_URL_EXPIRATION_MINUTES=15
MAX_UPLOAD_SIZE_MB=25
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_SENSITIVE_API_PER_MINUTE=60
